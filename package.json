{
  "name": "viucraft",
  "version": "2.0.0",
  "description": "JavaScript SDK for the Viucraft image processing service",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "image",
    "processing",
    "resize",
    "crop",
    "thumbnail",
    "viucraft"
  ],
  "author": "Viucraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BStormIT/viucraft-js"
  },
  "homepage": "https://github.com/BStormIT/viucraft-js#readme",
  "bugs": {
    "url": "https://github.com/BStormIT/viucraft-js/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.11",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.0.4"
  }
}
